{
  "name": "sumac",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.3",
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
